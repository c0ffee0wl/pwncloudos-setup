#!/usr/bin/env bash
# pwncloudos-setup — provision a Kali/Ubuntu/Debian box with PwnCloudOS tooling.
# Installs system prerequisites + the /opt tool tree, then runs the Python
# installer (python3 -m src.main install) which clones/installs every manifest
# tool and places launchers/profiles/menus. Never touches your .zshrc.
set -eo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# ---- pretty output (reused idioms from linux-setup.sh) ----
GREEN='\033[0;32m'; YELLOW='\033[0;33m'; RED='\033[0;31m'; CYAN='\033[0;36m'; NC='\033[0m'
log()  { echo -e "${GREEN}[$(date +'%H:%M:%S')]${NC} $1"; }
warn() { echo -e "${YELLOW}[WARN]${NC} $1"; }
error(){ echo -e "${RED}[ERROR]${NC} $1"; exit 1; }

# ---- fail clearly; remind that re-running is safe (all steps are idempotent) ----
on_err() {
    local rc=$?
    echo -e "\n${RED}[ERROR]${NC} pwncloudos-setup aborted (exit $rc). Completed steps are idempotent; re-running is safe."
    exit "$rc"
}
trap on_err ERR

# ---- flags ----
YES=false; DRY_RUN=false; NO_PREREQS=false; NO_CONFIGS=false; NO_DESKTOP=false
usage() {
    cat <<EOF
Usage: ./pwncloudos-setup [options]

Provision this host with the PwnCloudOS security toolset.

Options:
  -y, --yes          Skip confirmation prompts
  -n, --dry-run      Show what would happen; make no changes
      --no-prereqs   Skip system prerequisite installation
      --no-configs   Skip launchers/PowerShell profiles/menus (tools only)
      --no-desktop   Skip desktop menu entries and icons
  -h, --help         Show this help
EOF
}
while [ $# -gt 0 ]; do
    case "$1" in
        -y|--yes) YES=true ;;
        -n|--dry-run) DRY_RUN=true ;;
        --no-prereqs) NO_PREREQS=true ;;
        --no-configs) NO_CONFIGS=true ;;
        --no-desktop) NO_DESKTOP=true ;;
        -h|--help) usage; exit 0 ;;
        *) error "Unknown option: $1 (use --help)" ;;
    esac
    shift
done

# ---- run wrapper: honors --dry-run ----
run() {
    if [ "$DRY_RUN" = true ]; then
        echo -e "${CYAN}[dry-run]${NC} $*"
    else
        "$@"
    fi
}

# ---- distro detection ----
is_kali_linux() { grep -qi "kali" /etc/os-release 2>/dev/null; }
is_ubuntu() {
    [ -f /etc/os-release ] && . /etc/os-release
    [ "${ID:-}" = "ubuntu" ] || echo "${ID_LIKE:-}" | grep -qi "ubuntu"
}
if ! grep -qiE "(debian|ubuntu|kali|ID_LIKE=.*debian)" /etc/os-release 2>/dev/null; then
    error "This installer requires a Debian-based distribution (Kali, Ubuntu, or Debian)."
fi
ARCH="$(dpkg --print-architecture 2>/dev/null || uname -m)"
[ "$EUID" -eq 0 ] && warn "Running as root; prefer a normal user with sudo (user files would land under /root)."

log "Detected: $(. /etc/os-release; echo "$PRETTY_NAME") ($ARCH)"

# ---- confirmation ----
if [ "$YES" != true ] && [ "$DRY_RUN" != true ]; then
    read -r -p "$(echo -e "${YELLOW}Provision this host with the PwnCloudOS toolset? [y/N]: ${NC}")" ans
    case "$ans" in y|Y|yes|YES) ;; *) log "Aborted."; exit 0 ;; esac
fi

# ---- sudo ----
if [ "$DRY_RUN" != true ]; then
    log "Requesting sudo credentials..."
    sudo -v || error "sudo is required to install prerequisites and /opt tools."
fi

# ---- own this repo dir (safety net) ----
# If the repo was cloned into a root-owned location (e.g. `sudo git clone` into
# /opt) and ownership was never handed over, reclaim it so the user can run and
# update pwncloudos-setup without sudo. (The /opt tool dirs intentionally stay
# root-owned, matching PwnCloudOS — that is handled separately by the installer.)
if [ ! -O "$SCRIPT_DIR" ]; then
    log "Taking ownership of $SCRIPT_DIR for $USER..."
    run sudo chown -R "$USER":"$USER" "$SCRIPT_DIR"
fi

# ---- prerequisites ----
install_base_packages() {
    log "Installing base packages..."
    run sudo apt-get update || warn "apt-get update reported errors; continuing"
    # Required — without these nothing works, so abort if they can't be installed.
    run sudo apt-get install -y git curl ca-certificates python3 python3-pip python3-venv pipx \
        || error "Failed to install required base packages (git/python3/pipx)."
    # Optional — install one-by-one and only warn on failure, so a single
    # unavailable/renamed package (or mirror hiccup) can't abort the whole setup.
    local pkg
    for pkg in jq build-essential libssl-dev pkg-config golang-go python3-dev libffi-dev; do
        run sudo apt-get install -y "$pkg" \
            || warn "Optional package '$pkg' failed to install; related tools may be degraded"
    done
}

install_uv() {
    if command -v uv >/dev/null 2>&1; then log "uv already installed"; return 0; fi
    log "Installing uv (fast Python installer)..."
    run pipx install uv || warn "uv install failed; will fall back to pip"
}

install_pwsh() {
    if command -v pwsh >/dev/null 2>&1; then log "pwsh already installed"; return 0; fi
    log "Installing PowerShell (needed by ps_tools)..."
    if is_kali_linux; then
        run sudo apt-get install -y powershell || warn "powershell apt install failed (Kali)"
        return 0
    fi
    . /etc/os-release
    local deb="/tmp/packages-microsoft-prod.deb"
    if run curl -fsSL "https://packages.microsoft.com/config/${ID}/${VERSION_ID}/packages-microsoft-prod.deb" -o "$deb"; then
        run sudo dpkg -i "$deb" || warn "Microsoft repo package install failed"
        run sudo apt-get update || true
        run sudo apt-get install -y powershell || warn "pwsh install failed; ps_tools will be unavailable"
        run rm -f "$deb"
    else
        warn "No Microsoft repo for ${ID} ${VERSION_ID}; skipping pwsh (ps_tools need it)"
    fi
}

install_docker() {
    if command -v docker >/dev/null 2>&1; then log "Docker already installed"; return 0; fi
    log "Installing Docker CE (needed by bloodhound)..."
    local distro codename
    if is_ubuntu; then
        . /etc/os-release; distro="ubuntu"; codename="${UBUNTU_CODENAME:-$VERSION_CODENAME}"
        case "$codename" in resolute|questing|noble|jammy) ;; *) distro="debian"; codename="trixie" ;; esac
    else
        . /etc/os-release
        distro="debian"; codename="${VERSION_CODENAME:-trixie}"
        case "$codename" in trixie|bookworm|bullseye) ;; *) codename="trixie" ;; esac
    fi
    run sudo install -m 0755 -d /etc/apt/keyrings
    run sudo curl --proto '=https' --tlsv1.2 -fsSL "https://download.docker.com/linux/$distro/gpg" -o /etc/apt/keyrings/docker.asc \
        || { warn "Docker GPG fetch failed; skipping Docker (bloodhound unavailable)"; return 0; }
    run sudo chmod a+r /etc/apt/keyrings/docker.asc
    if [ "$DRY_RUN" = true ]; then
        echo -e "${CYAN}[dry-run]${NC} add docker.list for $distro/$codename and apt-get install docker-ce ..."
    else
        echo "deb [arch=$ARCH signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/$distro $codename stable" \
            | sudo tee /etc/apt/sources.list.d/docker.list >/dev/null
        sudo apt-get update
        sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin \
            || warn "Docker install failed; bloodhound will be unavailable"
        sudo systemctl enable docker 2>/dev/null || true
        sudo systemctl start docker 2>/dev/null || true
        sudo usermod -aG docker "$USER" 2>/dev/null || true
    fi
}

# Idempotently append a marked block to ~/.profile (skips if the marker is
# already present; honors --dry-run). Never touches .zshrc. Args:
#   $1 marker, $2 dry-run msg, $3 added msg, $4 already-present msg, $5.. body lines
append_profile_block() {
    local marker="$1" dry_msg="$2" added_msg="$3" present_msg="$4"; shift 4
    local profile="$HOME/.profile"
    if [ "$DRY_RUN" = true ]; then
        echo -e "${CYAN}[dry-run]${NC} $dry_msg"
    elif grep -qF "$marker" "$profile" 2>/dev/null; then
        log "$present_msg"
    else
        { echo ""; echo "$marker"; printf '%s\n' "$@"; } >> "$profile"
        log "$added_msg"
    fi
}

ensure_path_entries() {
    # Make pipx (~/.local/bin) and go-installed (~/go/bin, e.g. cloudfox,
    # aws-enumerator) tools runnable by name — both for future logins (~/.profile)
    # and for the rest of this run. Never touches .zshrc.
    append_profile_block "# pwncloudos-setup PATH" \
        "ensure ~/.local/bin and ~/go/bin on PATH via $HOME/.profile" \
        "Added ~/.local/bin and ~/go/bin to PATH in $HOME/.profile (re-login or 'source ~/.profile' to apply)" \
        "PATH entries already present in $HOME/.profile" \
        'case ":$PATH:" in *":$HOME/.local/bin:"*) ;; *) PATH="$HOME/.local/bin:$PATH" ;; esac' \
        'case ":$PATH:" in *":$HOME/go/bin:"*) ;; *) PATH="$HOME/go/bin:$PATH" ;; esac' \
        'export PATH'
    # Apply to the current process so the toolchain check and the Python verify
    # steps (which run tool --version) can find freshly-installed binaries.
    local d
    for d in "$HOME/.local/bin" "$HOME/go/bin"; do
        case ":$PATH:" in *":$d:"*) ;; *) PATH="$d:$PATH" ;; esac
    done
    export PATH
}

# Detect the terminal background and cache it in the global TERMINAL_BG (ported
# from linux-setup.sh). Primary: OSC 11 query of the live terminal; fallback:
# $COLORFGBG. The OSC query flips the tty into raw mode, so we do it only once.
# Sets a global (not echo) so it must be called directly, not via $(...).
detect_terminal_background() {
    if [ -n "${TERMINAL_BG:-}" ]; then return 0; fi
    TERMINAL_BG="unknown"

    local r g b lum reply oldstty bg hr hg hb

    # Primary: ask the terminal for its background color (OSC 11, BEL-terminated).
    if [ -t 0 ] && [ -t 1 ] && [ -e /dev/tty ]; then
        oldstty=$(stty -g < /dev/tty 2>/dev/null) || oldstty=""
        if [ -n "$oldstty" ]; then
            # Restore the terminal if interrupted mid-query, so a Ctrl-C during
            # the read can't leave it stuck in raw/no-echo mode.
            trap 'stty "$oldstty" < /dev/tty 2>/dev/null; trap - INT TERM HUP; exit 130' INT TERM HUP
            stty raw -echo min 0 time 0 < /dev/tty 2>/dev/null || true
            printf '\033]11;?\007' > /dev/tty 2>/dev/null || true
            IFS= read -r -d $'\007' -t 1 reply < /dev/tty 2>/dev/null || true
            stty "$oldstty" < /dev/tty 2>/dev/null || true
            trap - INT TERM HUP

            # Reply looks like: ESC]11;rgb:RRRR/GGGG/BBBB
            if [[ "$reply" =~ rgb:([0-9a-fA-F]+)/([0-9a-fA-F]+)/([0-9a-fA-F]+) ]]; then
                # Channels may be 1, 2, or 4 hex digits; normalize to 8-bit. A
                # 1-digit channel repeats (f -> ff = 255); wider forms keep their
                # top two digits (ffff -> ff, 2828 -> 28).
                hr=${BASH_REMATCH[1]}; hg=${BASH_REMATCH[2]}; hb=${BASH_REMATCH[3]}
                [ ${#hr} -eq 1 ] && hr=$hr$hr
                [ ${#hg} -eq 1 ] && hg=$hg$hg
                [ ${#hb} -eq 1 ] && hb=$hb$hb
                r=$((16#${hr:0:2})); g=$((16#${hg:0:2})); b=$((16#${hb:0:2}))
                lum=$(( (299*r + 587*g + 114*b) / 1000 ))   # BT.601, 0..255
                if [ "$lum" -lt 128 ]; then TERMINAL_BG="dark"; else TERMINAL_BG="light"; fi
            fi
        fi
    fi

    # Fallback: COLORFGBG = "fg;bg" (or "fg;default;bg"); low bg index => dark.
    # Require a ';' so a single-field (foreground-only) value isn't read as bg.
    if [ "$TERMINAL_BG" = "unknown" ] && [ -n "${COLORFGBG:-}" ] && [[ "$COLORFGBG" == *";"* ]]; then
        bg="${COLORFGBG##*;}"
        case "$bg" in
            0|1|2|3|4|5|6|8) TERMINAL_BG="dark" ;;
            7|9|1[0-5])      TERMINAL_BG="light" ;;
        esac
    fi

    return 0
}

# Decide the PowerShell theme (light only when positively detected; otherwise
# dark, which PowerShell's colors are optimized for) and opt out of pwsh
# telemetry. The detected theme is exported to the Python config phase, which
# writes the matching profile. Never touches .zshrc.
setup_pwsh_env() {
    detect_terminal_background
    if [ "$TERMINAL_BG" = "light" ]; then
        export PWNCLOUDOS_TERMINAL_BG="light"
    else
        export PWNCLOUDOS_TERMINAL_BG="dark"
    fi
    log "Terminal background: ${TERMINAL_BG} -> PowerShell ${PWNCLOUDOS_TERMINAL_BG} theme"

    append_profile_block "# pwncloudos-setup pwsh telemetry opt-out" \
        "export POWERSHELL_TELEMETRY_OPTOUT=1 via $HOME/.profile" \
        "Opted out of PowerShell telemetry in $HOME/.profile" \
        "PowerShell telemetry opt-out already present in $HOME/.profile" \
        'export POWERSHELL_TELEMETRY_OPTOUT=1'
    export POWERSHELL_TELEMETRY_OPTOUT=1
}

report_toolchains() {
    log "Toolchain availability (missing ones degrade related tool categories):"
    local t
    for t in git python3 pipx go pwsh docker; do
        if command -v "$t" >/dev/null 2>&1; then
            echo -e "  ${GREEN}[ OK ]${NC} $t"
        else
            echo -e "  ${YELLOW}[MISS]${NC} $t"
        fi
    done
}

if [ "$NO_PREREQS" != true ]; then
    install_base_packages
    install_uv
    install_pwsh
    install_docker
else
    log "Skipping prerequisites (--no-prereqs)."
fi

# ---- ensure user-local bin dirs are on PATH (pipx + go tools) ----
ensure_path_entries

# ---- detect terminal theme + opt out of pwsh telemetry (used by the profile install) ----
setup_pwsh_env

# ---- /opt tool tree (root-owned; Python clone uses sudo) ----
log "Creating /opt tool directories..."
for d in aws_tools azure_tools gcp_tools multi_cloud_tools ps_tools code_scanning cracking-tools; do
    run sudo mkdir -p "/opt/$d"
done

# ---- this repo's Python deps (global env, matches upstream) ----
log "Installing pwncloudos-sync Python dependencies..."
if UV_BIN="$(command -v uv 2>/dev/null)"; then
    run sudo "$UV_BIN" pip install --system --break-system-packages -r "$SCRIPT_DIR/requirements.txt" \
        || run sudo python3 -m pip install -r "$SCRIPT_DIR/requirements.txt" --break-system-packages
else
    run sudo python3 -m pip install -r "$SCRIPT_DIR/requirements.txt" --break-system-packages
fi

# ---- toolchain report ----
report_toolchains

# ---- hand off to the Python installer ----
PY_ARGS=(install)
[ "$YES" = true ] && PY_ARGS+=(--yes)
[ "$DRY_RUN" = true ] && PY_ARGS+=(--dry-run)
[ "$NO_CONFIGS" = true ] && PY_ARGS+=(--no-configs)
[ "$NO_DESKTOP" = true ] && PY_ARGS+=(--no-desktop)

log "Running the tool installer: python3 -m src.main ${PY_ARGS[*]}"
cd "$SCRIPT_DIR"
exec python3 -m src.main "${PY_ARGS[@]}"
